{
  "description": "Force-load Flutter/Dart conventions at session start when the project has a pubspec.yaml",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/force-flutter-knowledge.mjs\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
